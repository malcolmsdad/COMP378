Table Persons {
  PersonId integer [pk]
  Name varchar
  Address varchar
  BirthDate date [not null]
  PhoneNumber varchar
}

Table Employee {
  EmployeeId integer [pk]
  PersonId integer [not null]
  EmployeeTypeId integer [not null]
  HiredDate date
}

Table EmployeeTypes {
  EmployeeTypeId integer [pk]
  EmployeeTypeName varchar
}

Table Volunteer {
  VolunteerId integer [pk]
  EmployeeId integer [not null]
  Skill varchar
}

Table Physician {
  PhysicianId integer [pk]
  EmployeeId integer [not null]
  Specialty varchar
  PagerNumber varchar
}

Table Nurse {
  NurseId integer [pk]
  EmployeeId integer [not null]
  CertificateTypeName varchar [not null]
}

Table Technician {
  TechnicianId integer [pk]
  EmployeeId integer [not null]
}

Table TechnicianLaboratory {
  TechnicianId integer [not null]
  LaboratoryId integer [not null]

  Note: "M:N relationship between Technician and Laboratory"
}

Table Patient {
  PatientId integer [pk]
  PersonId integer [not null]
  PhysicianId integer [not null] // responsible physician
  ReferringPhysicianId integer [not null]
  CareCenterId integer [not null]
  AdmittanceTypeId integer [not null]
  AdmittedDate datetime [not null]
  Comments text
}

Table PatientResidents {
  PatientResidentId integer [pk]
  PatientId integer [not null]
  BedId integer [not null]
}

Table AdmittanceTypes {
  AdmittanceTypeId integer [pk]
  AdmittanceTypeName varchar
}

Table PatientVisit {
  VisitId integer [pk]
  PatientId integer [not null]
  VisitDate datetime [not null]
  Comments varchar
}

Table Treatments {
  TreatmentId integer [pk]
  TreatmentNumber integer
  TreatmentName varchar
}

Table TreatmentRecord {
  TreatmentRecordId integer [pk]
  PatientId integer [not null]
  PhysicianId integer [not null]
  TreatmentId integer [not null]
  TreatmentDate datetime [not null]
  TreatmentTime integer [not null]
  TreatmentResults varchar
}

Table CareCenter {
  CareCenterId integer [pk]
  Name varchar
  Location varchar
  CareCenterTypeId integer [not null]
}

Table CareCenterTypes {
  CareCenterTypeId integer [pk]
  CareCenterTypeName varchar
}

Table Beds {
  BedId integer [pk]
  RoomNumber integer
  CareCenterId integer
}

Table Laboratory {
  LaboratoryId integer [pk]
  Name varchar
  Location varchar
}

Table EmployeeCareCenterAssignment {
  AssignmentId integer [pk]
  EmployeeId integer [not null]
  CareCenterId integer [not null]
  IsNurseInCharge bool
}

Table EmployeeCareCenterAssignmentWorkEntry {
  WorkEntryId integer [pk]
  AssignmentId integer [not null]
  WorkWeekId integer [not null]
  Hours integer
}

Ref: Employee.PersonId > Persons.PersonId
Ref: Employee.EmployeeTypeId > EmployeeTypes.EmployeeTypeId

Ref: Volunteer.EmployeeId > Employee.EmployeeId
Ref: Physician.EmployeeId > Employee.EmployeeId
Ref: Nurse.EmployeeId > Employee.EmployeeId
Ref: Technician.EmployeeId > Employee.EmployeeId

Ref: TechnicianLaboratory.TechnicianId > Technician.TechnicianId
Ref: TechnicianLaboratory.LaboratoryId > Laboratory.LaboratoryId

Ref: Patient.PersonId > Persons.PersonId
Ref: Patient.PhysicianId > Physician.PhysicianId
Ref: Patient.ReferringPhysicianId > Physician.PhysicianId
Ref: Patient.CareCenterId > CareCenter.CareCenterId
Ref: Patient.AdmittanceTypeId > AdmittanceTypes.AdmittanceTypeId

Ref: PatientResidents.PatientId > Patient.PatientId
Ref: PatientResidents.BedId > Beds.BedId

Ref: PatientVisit.PatientId > Patient.PatientId

Ref: TreatmentRecord.PatientId > Patient.PatientId
Ref: TreatmentRecord.PhysicianId > Physician.PhysicianId
Ref: TreatmentRecord.TreatmentId > Treatments.TreatmentId

Ref: CareCenter.CareCenterTypeId > CareCenterTypes.CareCenterTypeId

Ref: Beds.CareCenterId > CareCenter.CareCenterId

Ref: EmployeeCareCenterAssignment.EmployeeId > Employee.EmployeeId
Ref: EmployeeCareCenterAssignment.CareCenterId > CareCenter.CareCenterId

Ref: EmployeeCareCenterAssignmentWorkEntry.AssignmentId > EmployeeCareCenterAssignment.AssignmentId